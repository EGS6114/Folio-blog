---
import BaseLayout from "../layouts/BaseLayout.astro";
import { sites } from "../data/sites";

// 按分类分组
const categories = new Map<string, typeof sites>();
for (const site of sites) {
  const cat = site.category;
  if (!categories.has(cat)) {
    categories.set(cat, []);
  }
  categories.get(cat)!.push(site);
}
// 转为数组方便遍历
const categoryGroups = Array.from(categories.entries());
---

<BaseLayout title="EGS-导航" titleText="EGS-导航" descText="个人收集的实用工具">
  <main>
    <!-- 遍历每个分类 -->
    {
      categoryGroups.map(([category, siteList]) => (
        <section class="category-section">
          <h3 class="category-title">{category}</h3>
          <ul class="site-list">
            {siteList.map((site) => (
              <li>
                <a href={site.url} target="_blank" rel="noopener noreferrer">
                  <strong>{site.name}</strong>
                </a>
                <span> — {site.desc}</span>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </main>
</BaseLayout>

<style>
  .category-section {
    margin-bottom: 2rem;
  }
  .category-title {
    font-size: 1.35rem;
    font-weight: 600;
    margin-bottom: 0.3rem;
    color: var(--color-text-secondary);
    border-bottom: 1px dashed var(--color-border);
    padding-bottom: 0.3rem;
  }
  .site-list {
    list-style: none;
    padding: 0;
  }
  .site-list li {
    margin: 0.6rem 0;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .site-list a {
    color: #a98ce0;
    text-decoration: none;
  }
  .site-list a:hover {
    text-decoration: underline;
  }
  .site-list span {
    color: var(--color-text-secondary);
  }
</style>
