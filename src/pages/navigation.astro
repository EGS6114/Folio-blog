---
import BaseLayout from "../layouts/BaseLayout.astro";
import { sites } from "../data/sites";

// 按分类分组
const categories = new Map<string, typeof sites>();
for (const site of sites) {
  const cat = site.category;
  if (!categories.has(cat)) {
    categories.set(cat, []);
  }
  categories.get(cat)!.push(site);
}
const categoryGroups = Array.from(categories.entries());
---

<BaseLayout title="EGS-导航" titleText="EGS-导航" descText="个人收集的实用工具">
  <main class="nav-page">
    <div class="container">
      <h1 class="page-title">EGS-导航</h1>

      {
        categoryGroups.map(([category, siteList]) => (
          <section class="category-section">
            <h2 class="category-title">{category}</h2>
            <div class="sites-grid">
              {siteList.map((site) => (
                <a
                  href={site.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="site-card"
                >
                  <h3 class="site-name">{site.name}</h3>
                  {site.desc && <p class="site-desc">{site.desc}</p>}
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </main>
</BaseLayout>

<style>
  .nav-page {
    padding: 2rem 0 3rem;
  }

  .page-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 2rem;
    text-align: center;
  }

  .category-section {
    margin-bottom: 2.5rem;
  }

  .category-title {
    font-size: 1.4rem;
    font-weight: 600;
    margin-bottom: 1rem;
    padding-bottom: 0.3rem;
    border-bottom: 2px solid var(--color-border, #e5e7eb);
    color: var(--color-text, #2c3e50);
  }

  .sites-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.2rem;
  }

  .site-card {
    display: block;
    padding: 1rem 1rem;
    background: var(--color-bg-secondary, #f8f9fa);
    border-radius: 12px;
    border: 1px solid var(--color-border, #e5e7eb);
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.03);
    text-decoration: none;
    color: var(--color-text, #2c3e50);
    transition:
      transform 0.15s ease,
      box-shadow 0.2s ease,
      background 0.2s ease;
  }

  .site-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
    background: var(--color-bg, #ffffff);
    text-decoration: none;
  }

  .site-name {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.25rem 0;
    color: var(--color-primary, #3b82f6);
  }

  .site-desc {
    font-size: 0.9rem;
    color: var(--color-text-secondary, #6c757d);
    margin: 0;
    line-height: 1.4;
  }

  /* 深色模式 */
  @media (prefers-color-scheme: dark) {
    .site-card {
      background: rgba(255, 255, 255, 0.04);
      border-color: rgba(255, 255, 255, 0.08);
    }
    .site-card:hover {
      background: rgba(255, 255, 255, 0.08);
    }
  }

  /* 移动端适配 */
  @media (max-width: 600px) {
    .sites-grid {
      grid-template-columns: 1fr; /* 单列 */
      gap: 0.8rem;
    }
    .category-title {
      font-size: 1.2rem;
    }
  }
</style>
