---
const navItems = [
  { title: "首页", href: "/" },
  { title: "导航", href: "/navigation" },
];

export interface Props {
  titleText?: string;
  descText?: string;
}
const { titleText, descText } = Astro.props;
const defaultTitle = "Folio-blog";
const defaultDesc = "记录学习、生活与思考";
const displayTitle = titleText || defaultTitle;
const displayDesc = descText ?? defaultDesc; // 允许空字符串
---

<header class="site-header">
  <div class="container">
    <!-- 导航栏（无边框） -->
    <nav class="navbar">
      <ul>
        {
          navItems.map((item) => (
            <li>
              <a href={item.href}>{item.title}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- 标题区域：上下各一条分割线 -->
    <div class="title-wrapper">
      <h1 class="site-title" style="font-size: 2.2rem;">
        <a href="/">{displayTitle}</a>
      </h1>
      {displayDesc && <p class="site-description">{displayDesc}</p>}
    </div>
  </div>
</header>

<style>
  .container {
    text-align: center;
  }

  .navbar ul {
    display: flex;
    justify-content: center;
    gap: 5rem;
    list-style: none;
    padding: 0.09rem 0;
    margin: 0 0 0.9rem 0;
  }
  .navbar a {
    text-decoration: none;
    color: #333;
    font-weight: 500;
    font-size: 1.1rem;
  }
  .navbar a:hover {
    color: #8662e9;
    text-decoration: underline;
  }

  /* 标题区域：上下各一条线 */
  .title-wrapper {
    border-top: 1px solid #eaeaea;
    border-bottom: 1px solid #eaeaea;
    padding: 0.5rem 0;
    margin-bottom: 0.5rem;
  }

  .site-title a {
    color: inherit;
    text-decoration: none;
  }
  .site-description {
    color: #666;
    margin-top: 0.2rem;
    font-size: 0.95rem;
  }
</style>
